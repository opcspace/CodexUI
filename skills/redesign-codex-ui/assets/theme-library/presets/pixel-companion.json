{
  "schemaVersion": 1,
  "id": "pixel-companion",
  "label": "Pixel Companion",
  "category": "digital-character",
  "tags": ["virtual-idol", "game", "mascot", "playful"],
  "derivedFrom": "original-archetype",
  "concept": {"identityIntensity": "high", "thesis": "A friendly virtual companion adds delight while the coding workspace stays crisp and fast.", "mood": ["playful", "responsive", "optimistic"], "forbiddenMotifs": ["fake-terminal-noise", "unreadable-pixel-font", "flashing-animation"]},
  "layout": {"archetype": "hud-companion-workspace", "navigation": "quest-log-rail", "hero": "character-status-panel", "composer": "command-console-soft", "density": "medium-high"},
  "palette": {"canvas": "#171A2B", "surface": "#222641", "surfaceRaised": "#2A3050", "ink": "#F1F4FF", "mutedInk": "#AAB3D5", "accent": "#55D6BE", "accentSoft": "#214B4B", "line": "#3D456B", "focus": "#91F3E0"},
  "typography": {"display": "rounded-display", "body": "ui-sans", "code": "system-monospace", "accent": "pixel-label-only"},
