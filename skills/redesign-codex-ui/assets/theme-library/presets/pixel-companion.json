  "motion": {"character": "two-frame-bounce", "durationMs": 120, "reducedMotion": "instant"},
  "mediaSlots": [{"id": "characterSprite", "role": "hero", "aspect": "1:1", "focalPoint": "50% 40%", "fallback": "pixel-monogram"}, {"id": "avatar", "role": "profile", "aspect": "1:1", "focalPoint": "50% 40%", "fallback": "status-orb"}],
  "quickActions": [{"id": "explore", "label": "Scan the map"}, {"id": "build", "label": "Start a new quest"}, {"id": "review", "label": "Inspect the loadout"}, {"id": "fix", "label": "Recover the mission"}],
  "responsive": {"narrowNavigation": "quest-drawer", "narrowHero": "compact-status-card", "narrowCards": "two-then-one", "hideMotifs": ["speech-tail"], "missingMedia": "status-orb"},
  "assetPolicy": {"provenance": "required", "remoteHotlink": false, "licensedOrOwned": true},
  "accessibility": {"contrastTarget": "WCAG-AA", "preserveSemanticStates": true, "decorationAriaHidden": true}
